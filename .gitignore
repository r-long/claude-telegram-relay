cron/prompts/*.md
!cron/prompts/example.md

# User-specific service files (generated from daemon/ templates)
daemon/claude-relay.service.local
sessions.json

# Runtime files
*.lock
!bun.lock
*.log
logs/
temp/
uploads/
session.json

