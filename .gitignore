# Environment
.env
.env.local

# Secrets — anything in any .secrets/ folder, OAuth tokens, service accounts
**/.secrets/
*-oauth-*.json
*-service-account*.json
google-calendar-sa.json

# Supabase CLI temp
supabase/.temp/

# Dependencies
node_modules/

# Bun
bun.lockb

# Personal config (keep examples, ignore actual)
config/profile.md
config/SOUL.md
config/IDENTITY.md
config/USER.md
config/schedule.json
config/channels.json
config/memory/

